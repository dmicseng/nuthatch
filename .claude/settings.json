{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment_purpose": "Permissions for Claude Code in the Nuthatch repo. Commands in 'allow' run without prompting. Commands in 'ask' prompt once per session. 'deny' commands are blocked outright.",

  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",

      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck)",
      "Bash(npm run format)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm list:*)",
      "Bash(npm outdated)",
      "Bash(npm --version)",
      "Bash(node --version)",

      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx vitest:*)",
      "Bash(npx prisma validate)",
      "Bash(npx prisma format)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma studio)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(tree:*)",
      "Bash(wc:*)",

      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",

      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Glob(**)",
      "Grep(**)"
    ],

    "ask": [
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm ci)",
      "Bash(npx create-next-app:*)",
      "Bash(npx shadcn:*)",

      "Bash(npx prisma migrate:*)",
      "Bash(npx prisma db push)",
      "Bash(npx prisma db seed)",
      "Bash(npx prisma db pull)",
      "Bash(npm run db:*)",

      "Bash(docker compose:*)",
      "Bash(docker:*)",

      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",

      "Bash(mv:*)",
      "Bash(rm:*)",

      "Bash(curl:*)",
      "Bash(wget:*)",

      "WebFetch(**)",
      "WebSearch(**)"
    ],

    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf ..*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod 777:*)",
      "Bash(chown:*)",

      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",

      "Bash(curl:* | sh)",
      "Bash(curl:* | bash)",
      "Bash(wget:* | sh)",
      "Bash(wget:* | bash)",

      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(cat .env)",
      "Bash(cat .env.*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",

      "Bash(docker system prune:*)",
      "Bash(docker volume rm:*)",

      "Bash(eval:*)"
    ]
  },

  "_comment_usage": "To override per-session, use .claude/settings.local.json (gitignored). This file is committed and shared with contributors.",

  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [],
    "Notification": []
  }
}
