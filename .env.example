# Nuthatch environment configuration
# Copy this file to .env and fill in the values before running docker compose up.

# ---------------------------------------------------------------------
# REQUIRED: secret key used for encryption
# Generate with: openssl rand -base64 48
# Do not lose this. If lost, all encrypted fields become unrecoverable.
# ---------------------------------------------------------------------
NUTHATCH_SECRET_KEY=

# ---------------------------------------------------------------------
# REQUIRED: database password
# Generate with: openssl rand -base64 24
# ---------------------------------------------------------------------
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------
# REQUIRED: initial admin credentials
# You will be prompted to change the password on first login.
# ---------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ---------------------------------------------------------------------
# Public URL where Nuthatch is accessible.
# Used for generating links in emails, OAuth callbacks, etc.
# Set this to your real domain when deploying behind a reverse proxy.
# ---------------------------------------------------------------------
NUTHATCH_PUBLIC_URL=http://localhost:3000

# ---------------------------------------------------------------------
# Optional: port mapping (default 3000)
# ---------------------------------------------------------------------
NUTHATCH_PORT=3000

# ---------------------------------------------------------------------
# Optional: email configuration (for renewal reminders, alerts)
# Leave blank to disable email features.
# ---------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=nuthatch@your-domain.com

# ---------------------------------------------------------------------
# Optional: license key for Team tier features (SSO, audit, RBAC)
# Leave blank for the Community edition (fully functional without this).
# ---------------------------------------------------------------------
NUTHATCH_LICENSE_KEY=
